  const addAttendee = () => {
    if (!attendeeName.trim() || !attendeeEmail.trim()) {
      alert("м°ём„қмһҗ мқҙлҰ„кіј мқҙл©”мқјмқ„ лӘЁл‘җ кё°мһ…н•ҙ мЈјм„ёмҡ”.");
