    setAttendeeEmail("");
  };

  const removeAttendee = (idx: number) => {
    setTempAttendees(tempAttendees.filter((_, i) => i !== idx));
  };

  // 3. мӢӨмӢңк°„ мқҢм„ұмқёмӢқ (STT) м ңм–ҙ
  const startSTT = async () => {
    const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    if (!SpeechRecognition) {
      alert("нҳ„мһ¬ лёҢлқјмҡ°м ҖлҠ” мқҢм„ұ мқёмӢқмқ„ м§Җмӣҗн•ҳм§Җ м•ҠмҠөлӢҲлӢӨ. нҒ¬лЎ¬мқҙлӮҳ м—җм§Җ лёҢлқјмҡ°м ҖлҘј мӮ¬мҡ©н•ҳмӢңкұ°лӮҳ [л…№мқҢ нҢҢмқј м—…лЎңл“ң] кё°лҠҘмқ„ мқҙмҡ©н•ҙ мЈјм„ёмҡ”.");
      return;
    }

    // лӘ…мӢңм ҒмңјлЎң STT к°ҖлҸҷ мғҒнғңлЎң кё°лЎқ
    shouldSTTActiveRef.current = true;

    // рҹҺҷпёҸ л§ҲмқҙнҒ¬ мҠӨнҠёлҰј нҡҚл“қ л°Ҹ MediaRecorder л°ұк·ёлқјмҡҙл“ң л…№мқҢ мӢңмһ‘
    let stream: MediaStream | null = null;
    try {
      stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      setAudioStream(stream);
      
      // кё°мЎҙм—җ лҲ„м Ғлҗң мҳӨл””мҳӨ мІӯнҒ¬ л°ұм—…мқҙ мһҲлӢӨл©ҙ ліөмӣҗн•ҳм—¬ мқҙм–ҙл°ӣкі , м—Ҷмңјл©ҙ мҙҲкё°нҷ”
      const meetId = selectedMeeting?.id;
      if (meetId && typeof window !== "undefined" && (window as any).__ongoing_meeting_audio_chunks?.[meetId]) {
        audioChunksRef.current = [...(window as any).__ongoing_meeting_audio_chunks[meetId]];
      } else {
        audioChunksRef.current = [];
      }

      const mediaRecorder = new MediaRecorder(stream);
      mediaRecorder.ondataavailable = (e) => {
        if (e.data.size > 0) {
          audioChunksRef.current.push(e.data);
          
          // м „м—ӯ л°ұм—…м—җлҸ„ мӢӨмӢңк°„ лҸҷмӢң лҲ„м Ғ
          if (meetId && typeof window !== "undefined") {
            (window as any).__ongoing_meeting_audio_chunks = (window as any).__ongoing_meeting_audio_chunks || {};
            (window as any).__ongoing_meeting_audio_chunks[meetId] = (window as any).__ongoing_meeting_audio_chunks[meetId] || [];
            (window as any).__ongoing_meeting_audio_chunks[meetId].push(e.data);
          }
        }
      };
      mediaRecorder.onstop = () => {
        console.log("рҹҺҷпёҸ MediaRecorder stopped. Chunks length:", audioChunksRef.current.length);
        if (audioChunksRef.current && audioChunksRef.current.length > 0) {
          const audioBlob = new Blob(audioChunksRef.current, { type: "audio/webm" });
          const blobUrl = URL.createObjectURL(audioBlob);
          setTempAudioUrl(blobUrl);
        }
      };
      mediaRecorderRef.current = mediaRecorder;
      mediaRecorder.start(1000); // 1мҙҲ лӢЁмң„ лҚ°мқҙн„° мҲҳм§‘
    } catch (micErr) {
      console.warn("рҹҺҷпёҸ л§ҲмқҙнҒ¬ мқҢм„ұ л…№мқҢ мӢңмһ‘ мӢӨнҢЁ (STTл§Ң к°ҖлҸҷ):", micErr);
    }

    const rec = new SpeechRecognition();
    rec.continuous = true;
    rec.interimResults = true;
    rec.lang = "ko-KR";

    rec.onstart = () => {
      setIsRecording(true);
    };

    rec.onresult = (event: any) => {
      let interim = "";
      let final = "";

      for (let i = event.resultIndex; i < event.results.length; ++i) {
        if (event.results[i].isFinal) {
          final += event.results[i][0].transcript;
        } else {
          interim += event.results[i][0].transcript;
        }
      }

      if (interim) {
        setCurrentSpeech(interim);
      }

      if (final) {
        const timeStr = new Date().toLocaleTimeString("ko-KR", { hour12: false, hour: "2-digit", minute: "2-digit", second: "2-digit" });
        const newId = `stt-${Date.now()}-${Math.floor(Math.random() * 1000)}`;
        setTranscript(prev => [...prev, {
          id: newId,
          speaker: speechSpeakerRef.current,
          text: final.trim(),
          time: timeStr,
          isDiarizing: true
        }]);
        setCurrentSpeech("");
        
        // л°ұк·ёлқјмҡҙл“ң мһҗлҸҷ нҷ”мһҗ нҢҗлі„ нҠёлҰ¬кұ°
        triggerAutoDiarization(newId, final.trim());
      }
    };

    rec.onerror = (e: any) => {
      // no-speechмқҳ кІҪмҡ° лӢЁмҲң лҢҖкё° м—°мһҘмқҙлҜҖлЎң л¶Ҳн•„мҡ”н•ң console.error л»ҳкұҙ лЎңк·ёлҘј л°©м§Җн•ҳкё° мң„н•ҙ console.logлЎң кё°лЎқ
      if (e.error === "no-speech") {
        console.log("рҹҺӨ мқјм • мӢңк°„ лҸҷм•Ҳ л°ңнҷ”к°Җ к°җм§Җлҗҳм§Җ м•Ҡм•„ л§ҲмқҙнҒ¬ лҢҖкё° лӘЁл“ңлЎң м „нҷҳн•©лӢҲлӢӨ. (no-speech)");
        return;
      }

      console.error("мқҢм„ұмқёмӢқ м—җлҹ¬:", e.error || e);
      
      // мӮ¬мҡ©мһҗ м№ңнҷ”м Ғ м—җлҹ¬ л©”мӢңм§Җ м•ҢлҰј л°Ҹ мҳҲмҷё мІҳлҰ¬
      if (e.error === "not-allowed" || e.error === "service-not-allowed") {
        alert("рҹҺӨ л§ҲмқҙнҒ¬ мӮ¬мҡ© к¶Ңн•ңмқҙ кұ°л¶Җлҗҳм—ҲмҠөлӢҲлӢӨ.\nлёҢлқјмҡ°м Җ мЈјмҶҢм°Ҫ мҷјмӘҪ мһҗл¬јмҮ /м„Өм • м•„мқҙмҪҳмқ„ лҲҢлҹ¬ л§ҲмқҙнҒ¬ м ‘к·јмқ„ н—Ҳмҡ©н•ҙ мЈјмӢӯмӢңмҳӨ.");
        shouldSTTActiveRef.current = false;
        setIsRecording(false);
      } else if (e.error === "audio-capture") {
        alert("рҹҺӨ кё°кё°м—җ л§ҲмқҙнҒ¬к°Җ м—°кІ°лҗҳм–ҙ мһҲм§Җ м•Ҡкұ°лӮҳ к°җм§Җлҗҳм§Җ м•ҠмҠөлӢҲлӢӨ.\nл§ҲмқҙнҒ¬ м—°кІ° мғҒнғңлҘј лӢӨмӢң н•ң лІҲ нҷ•мқён•ҙ мЈјмӢӯмӢңмҳӨ.");
        shouldSTTActiveRef.current = false;
        setIsRecording(false);
      } else if (e.error === "network") {
        alert("рҹҢҗ кө¬кёҖ мқҢм„ұмқёмӢқ м„ңлІ„мҷҖмқҳ л„ӨнҠёмӣҢнҒ¬ м—°кІ°мқҙ мӣҗнҷңн•ҳм§Җ м•ҠмҠөлӢҲлӢӨ.\nмһ мӢң нӣ„ лӢӨмӢң мӢңлҸ„н•ҙ мЈјмӢӯмӢңмҳӨ.");
        shouldSTTActiveRef.current = false;
        setIsRecording(false);
      }
    };

    rec.onend = () => {
      // мӮ¬мҡ©мһҗк°Җ лӘ…мӢңм ҒмңјлЎң лҒ„м§Җ м•Ҡм•ҳлҠ”лҚ° лҒҠкёҙ кІҪмҡ°(мҳҲ: no-speechлӮҳ мқјм • нғҖмһ„м•„мӣғ), мһҗлҸҷ мһ¬м—°кІ° мӢңлҸ„
      if (shouldSTTActiveRef.current && recognitionRef.current) {
        console.log("рҹҺӨ мқҢм„ұмқёмӢқ м„ём…ҳ л§ҢлЈҢ к°җм§Җ -> л°ұк·ёлқјмҡҙл“ң мһҗлҸҷ мһ¬м—°кІ° к°ңмӢң...");
        // мқҙм „ м„ём…ҳмқҙ лёҢлқјмҡ°м Җм—җм„ң мҷ„м „нһҲ м •лҰ¬лҗң нӣ„ мӢ к·ң м„ём…ҳмқ„ м—ҙ мҲҳ мһҲкІҢ 100ms м§Җм—° кё°лҸҷ м Ғмҡ© (нғҖмқҙл°Қ көҗм°© мҳҲл°©)
        setTimeout(() => {
          if (shouldSTTActiveRef.current && recognitionRef.current) {
            try {
              recognitionRef.current.start();
            } catch (startErr) {
              console.warn("рҹҺӨ мқҢм„ұмқёмӢқ мһ¬к°ҖлҸҷ мӢңлҸ„ мӢӨнҢЁ (мһ¬мӢңлҸ„ мҳҲм •):", startErr);
              setTimeout(() => {
                if (shouldSTTActiveRef.current && recognitionRef.current) {
                  try { recognitionRef.current.start(); } catch (err) {}
                }
              }, 1000);
            }
          }
        }, 100);
      } else {
        setIsRecording(false);
      }
    };

    recognitionRef.current = rec;
    rec.start();
  };

  const stopSTT = () => {
    // мӮ¬мҡ©мһҗк°Җ лӘ…мӢңм ҒмңјлЎң STTлҘј л№„нҷңм„ұнҷ”н•Ё
    shouldSTTActiveRef.current = false;

    if (recognitionRef.current) {
      recognitionRef.current.stop();
      recognitionRef.current = null;
    }

    // рҹҺҷпёҸ MediaRecorder л°Ҹ л§ҲмқҙнҒ¬ мҠӨнҠёлҰј м •м§Җ
    if (mediaRecorderRef.current && mediaRecorderRef.current.state !== "inactive") {
      mediaRecorderRef.current.stop();
    }
    if (audioStream) {
      audioStream.getTracks().forEach(track => track.stop());
      setAudioStream(null);
    }

    setIsRecording(false);
    setCurrentSpeech("");
  };

  // нҡҢмқҳ мӨ‘ лҸҷм ҒмңјлЎң мһ„мӢң нҷ”мһҗ м¶”к°Җ
  const handleAddSpeaker = () => {
    setActiveSpeakers(prev => {
      const numbers = prev.map(s => parseInt(s.replace("нҷ”мһҗ ", "")) || 0);
      const maxNum = numbers.length > 0 ? Math.max(...numbers) : 0;
      const nextSpeaker = `нҷ”мһҗ ${maxNum + 1}`;
      setSpeechSpeaker(nextSpeaker);
      return [...prev, nextSpeaker];
    });
  };

  // 3-1. л°ұк·ёлқјмҡҙл“ң AI мһҗлҸҷ нҷ”мһҗ л¶„лҰ¬ (Diarization)
  const triggerAutoDiarization = async (transcriptId: string, text: string) => {
    // м§Ғм „ 5к°ңмқҳ лҢҖнҷ” л¬ёл§Ҙ м •ліҙ мҲҳм§‘
    const context = transcript.slice(-5).map(t => ({ speaker: t.speaker, text: t.text }));

    try {
      const res = await fetch("/api/meeting-minutes/diarize", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          text,
          attendees: activeSpeakers, // лҸҷм Ғ к°Җм№ӯ нҷ”мһҗ лҰ¬мҠӨнҠё м „мҶЎ
          context
        })
      });
      const data = await res.json();
      if (data.success && data.speaker) {
        setTranscript(prev => prev.map(item => 
          item.id === transcriptId 
            ? { ...item, speaker: data.speaker, isDiarizing: false }
            : item
        ));
      } else {
        setTranscript(prev => prev.map(item => 
          item.id === transcriptId 
            ? { ...item, isDiarizing: false }
            : item
        ));
      }
    } catch (err) {
      console.error("мһҗлҸҷ нҷ”мһҗ л¶„лҰ¬ мІҳлҰ¬ мӢӨнҢЁ:", err);
      setTranscript(prev => prev.map(item => 
        item.id === transcriptId 
          ? { ...item, isDiarizing: false }
          : item
      ));
    }
  };

  // 4. нҡҢмқҳ л…№мқҢ/н…ҚмҠӨнҠё нҢҢмқј м—…лЎңл“ң л°Ҹ л¶„м„қ
  const handleAudioUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    if (!selectedMeeting) {
      alert("м§„н–ү мӨ‘мқё нҡҢмқҳк°Җ м—ҶмҠөлӢҲлӢӨ. лЁјм Җ нҡҢмқҳлҘј к°ңм„Өн•ҙ мЈјм„ёмҡ”.");
      return;
    }

    // нҢҢмқјлӘ…(нҷ•мһҘмһҗ м ңкұ°)мңјлЎң нҡҢмқҳлӘ… м„Өм •
    const rawFileName = file.name;
    const cleanTitle = rawFileName.substring(0, rawFileName.lastIndexOf('.')) || rawFileName;
    const isTextFile = file.type === "text/plain" || rawFileName.endsWith(".txt");

    setIsAudioAnalyzing(true);
    setAudioAnalysisStep("1лӢЁкі„: нҢҢмқј м„ңлІ„ м—…лЎңл“ң л°Ҹ нҡҢмқҳлӘ… лҸҷкё°нҷ” мӨ‘...");

    try {
      // нҡҢмқҳлӘ… лЁјм Җ лҸҷкё°нҷ”
      await fetch("/api/meeting-minutes", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          action: "sync",
          meetingId: selectedMeeting.id,
          title: cleanTitle
        })
      });

      setSelectedMeeting((prev: any) => ({
        ...prev,
        title: cleanTitle
      }));

      // 1. нҢҢмқј м—…лЎңл“ң API нҳём¶ң
      const formData = new FormData();
      formData.append("file", file);

      const uploadRes = await fetch("/api/meeting-minutes/upload", {
        method: "POST",
        body: formData
      });
      const uploadData = await uploadRes.json();

      if (!uploadData.success) {
        throw new Error(uploadData.error || "нҢҢмқј м—…лЎңл“ңм—җ мӢӨнҢЁн–ҲмҠөлӢҲлӢӨ.");
      }

      let formattedTranscript = [];

      if (isTextFile) {
        setAudioAnalysisStep("2лӢЁкі„: Gemini AI лҢҖнҷ” лӮҙмҡ© л°Ҹ нҷ”мһҗ л¶„м„қ мӨ‘...");

        // н…ҚмҠӨнҠё лҢҖнҷ”лЎқ л¶„м„қ API нҳём¶ң
        const analyzeRes = await fetch("/api/meeting-minutes/analyze-text", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ textUrl: uploadData.audioUrl })
        });
        const analyzeData = await analyzeRes.json();

        if (!analyzeData.success) {
          throw new Error(analyzeData.error || "н…ҚмҠӨнҠё лҢҖнҷ”лЎқ л¶„м„қм—җ мӢӨнҢЁн–ҲмҠөлӢҲлӢӨ.");
        }

        formattedTranscript = (analyzeData.transcript || []).map((item: any, idx: number) => ({
          id: `upload-${Date.now()}-${idx}`,
          speaker: item.speaker || "лҜёмғҒ",
          time: item.time || "00:00",
          text: item.text || ""
        }));

        setTranscript(formattedTranscript);

        setSelectedMeeting((prev: any) => ({
          ...prev,
          meeting_type: 'text'
        }));
        setTempAudioUrl("");

        // м§„н–ү мӨ‘мқё мғҒнғң лҢҖнҷ”лЎқ лҸҷкё°нҷ” (нҡҢмқҳ нғҖмһ…лҸ„ н•Ёк»ҳ лҸҷкё°нҷ”)
        await fetch("/api/meeting-minutes", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            action: "sync",
            meetingId: selectedMeeting.id,
            transcript: formattedTranscript,
            meetingType: 'text'
          })
        });

        alert("рҹҺү н…ҚмҠӨнҠё лҢҖнҷ”лЎқ л¶„м„қ л°Ҹ нҢҢмӢұмқҙ м„ұкіөм ҒмңјлЎң мҷ„лЈҢлҗҳм—ҲмҠөлӢҲлӢӨ!");

      } else {
        setAudioAnalysisStep("2лӢЁкі„: Gemini AI мҳӨл””мҳӨ л¶„м„қ л°Ҹ нҷ”мһҗ л¶„лҘҳ мӨ‘...");

        // мҳӨл””мҳӨ л¶„м„қ API нҳём¶ң
        const analyzeRes = await fetch("/api/meeting-minutes/analyze-audio", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ audioUrl: uploadData.audioUrl })
        });
        const analyzeData = await analyzeRes.json();

        if (!analyzeData.success) {
          throw new Error(analyzeData.error || "мҳӨл””мҳӨ л¶„м„қм—җ мӢӨнҢЁн–ҲмҠөлӢҲлӢӨ.");
        }

        // 3. м¶”м¶ңлҗң лҢҖнҷ”лЎқ м Ғмҡ©
        formattedTranscript = (analyzeData.transcript || []).map((item: any, idx: number) => ({
          id: `upload-${Date.now()}-${idx}`,
          speaker: item.speaker || "лҜёмғҒ",
          time: item.time || "00:00",
          text: item.text || ""
        }));

        setTranscript(formattedTranscript);
        
        setSelectedMeeting((prev: any) => ({
          ...prev,
          audio_url: uploadData.audioUrl,
          meeting_type: 'audio'
        }));
        setTempAudioUrl(uploadData.audioUrl);

        // м§„н–ү мӨ‘мқё мғҒнғң лҢҖнҷ”лЎқ лҸҷкё°нҷ” (мҳӨл””мҳӨ urlлҸ„ н•Ёк»ҳ лҸҷкё°нҷ”)
        await fetch("/api/meeting-minutes", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            action: "sync",
            meetingId: selectedMeeting.id,
            transcript: formattedTranscript,
            audioUrl: uploadData.audioUrl,
            meetingType: 'audio'
          })
        });

        alert("рҹҺү нҡҢмқҳ мҳӨл””мҳӨ нҢҢмқј л¶„м„қ л°Ҹ лҢҖнҷ”лЎқ м¶”м¶ңмқҙ м„ұкіөм ҒмңјлЎң мҷ„лЈҢлҗҳм—ҲмҠөлӢҲлӢӨ!");
      }
    } catch (err: any) {
      console.error("мҳӨл””мҳӨ м—…лЎңл“ң л¶„м„қ мӢӨнҢЁ:", err);
      alert(err.message || "мҳӨл””мҳӨ л¶„м„қ мӨ‘ мҳӨлҘҳк°Җ л°ңмғқн–ҲмҠөлӢҲлӢӨ.");
    } finally {
      setIsAudioAnalyzing(false);
      setAudioAnalysisStep("");
    }
  };

  // 5. кіјкұ° нҡҢмқҳ мӢӨмӢңк°„ мӢңл§ЁнӢұ м¶”мІң м—°кі„
  const triggerSemanticRecommendation = async () => {
    if (transcript.length === 0) return;
    
    const lastThree = transcript.slice(-3).map(t => `${t.speaker}: ${t.text}`).join("\n");

    try {
      const res = await fetch("/api/meeting-minutes/recommend", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ currentText: lastThree })
      });
      const data = await res.json();
      if (data.success && data.recommendations) {
        setRecommendedMeetings(data.recommendations);
      }
    } catch (e) {
      console.error("мӢңл§ЁнӢұ м¶”мІң м—°лҸҷ мӢӨнҢЁ:", e);
    }
  };

  // 6. нҡҢмқҳ мӨ‘ AI мӢӨмӢңк°„ мӨ‘к°„ мҡ”м•Ҫ/м ңм–ё
  const handleGetInterimAdvice = async () => {
    if (transcript.length === 0) {
      alert("нҡҢмқҳлЎқм—җ кё°лЎқлҗң лҢҖнҷ” лӮҙмҡ©мқҙ м—ҶмҠөлӢҲлӢӨ. лЁјм Җ мқҢм„ұ мһ…л ҘмқҙлӮҳ л…№мқҢ нҢҢмқј м—…лЎңл“ңлҘј н•ҙ мЈјм„ёмҡ”.");
      return;
    }

    setIsAnalyzingInterim(true);
    setShowInterimModal(true);

    try {
      const res = await fetch("/api/meeting-minutes/interim", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ transcript })
      });
      const data = await res.json();
      if (data.success) {
        setInterimAdvice(data.analysis);
      } else {
        setInterimAdvice("AIмқҳ н”јл“ңл°ұ л¶„м„қмқ„ к°Җм ёмҳӨлҠ” лҸ„мӨ‘ мҳӨлҘҳк°Җ л°ңмғқн–ҲмҠөлӢҲлӢӨ.");
      }
    } catch (e) {
      console.error("мӨ‘к°„ м ңм–ё мҡ”мІӯ мӢӨнҢЁ:", e);
      setInterimAdvice("л„ӨнҠёмӣҢнҒ¬ м—°кІ° мӢӨнҢЁлЎң мқён•ҙ мӨ‘к°„ мҡ”м•Ҫмқ„ м ңкіөн•  мҲҳ м—ҶмҠөлӢҲлӢӨ.");
    } finally {
      setIsAnalyzingInterim(false);
    }
  };

  // 7. нҡҢмқҳ мў…лЈҢ м „ л§Өн•‘ нҢқм—… мҳӨн”Ҳ
  const handleCompleteMeeting = async () => {
    if (transcript.length === 0) {
      alert("лҢҖнҷ”лЎқмқҙ л№„м–ҙмһҲм–ҙ нҡҢмқҳлҘј мҷ„лЈҢн•  мҲҳ м—ҶмҠөлӢҲлӢӨ.");
      return;
    }

    // л…№мқҢ мһҗлҸҷ мӨ‘лӢЁ
    stopSTT();

    // мӢӨм ңлЎң лҢҖнҷ”лЎқм—җ мӮ¬мҡ©лҗң кі мң  нҷ”мһҗл“Ө лӘ©лЎқ мҲҳм§‘
    const uniqueSpeakers = Array.from(new Set(transcript.map(item => item.speaker)));
    
    // мҙҲкё° л§Өн•‘к°’ м„Өм • (кё°ліём ҒмңјлЎң нҷ”мһҗлӘ…кіј л§Өм№ӯлҗ  мӢӨм ң мқҙлҰ„мқ„ л№Ҳ к°’ лҳҗлҠ” мң мӮ¬ мқёл¬јлЎң мӮ¬м „ л°”мқёл”©)
    let attendeesList: string[] = [];
    if (selectedMeeting) {
      try {
        const parsed = JSON.parse(selectedMeeting.attendees || "[]");
        attendeesList = parsed.map((a: any) => a.name);
      } catch (e) {
        console.error(e);
      }
    }

    const initialMapping: Record<string, string> = {};
    uniqueSpeakers.forEach((sp) => {
      if (sp.startsWith("нҷ”мһҗ ")) {
        const num = parseInt(sp.replace("нҷ”мһҗ ", "")) || 0;
        if (num > 0 && attendeesList[num - 1]) {
          initialMapping[sp] = attendeesList[num - 1];
        } else {
          initialMapping[sp] = "";
        }
      } else {
        initialMapping[sp] = sp;
      }
    });

    setSpeakerMapping(initialMapping);
    setShowMappingModal(true);
  };

  // 7-1. нҷ”мһҗ л§Өн•‘ л°Ҹ мөңмў… AI мҡ”м•Ҫ мҷ„лЈҢ мІҳлҰ¬
  const handleSaveWithSpeakerMapping = async () => {
    const unmapped = Object.entries(speakerMapping).filter(([k, v]) => k.startsWith("нҷ”мһҗ ") && !v.trim());
    if (unmapped.length > 0) {
      const confirmSave = confirm(`м•„м§Ғ л§Өн•‘лҗҳм§Җ м•ҠмқҖ мһ„мӢң нҷ”мһҗк°Җ мЎҙмһ¬н•©лӢҲлӢӨ. (${unmapped.map(([k]) => k).join(", ")})\nл§Өн•‘лҗҳм§Җ м•ҠмқҖ нҷ”мһҗлҠ” мӣҗлһҳмқҳ мһ„мӢң мқҙлҰ„ к·ёлҢҖлЎң нҡҢмқҳлЎқм—җ кё°лЎқлҗ©лӢҲлӢӨ. к·ёлҢҖлЎң м§„н–үн•ҳмӢңкІ мҠөлӢҲк№Ң?`);
      if (!confirmSave) return;
    }

    setShowMappingModal(false);
    setIsCompleting(true);

    // рҹҺҷпёҸ MediaRecorder лҚ°мқҙн„° н”Ңлҹ¬мӢңлҘј мң„н•ң лҜём„ё л”ңл Ҳмқҙ ліҙмһҘ
    await new Promise(resolve => setTimeout(resolve, 300));

    // рҹҺҷпёҸ л…№мқҢ мҳӨл””мҳӨ нҢҢмқј м„ңлІ„ м—…лЎңл“ң мІҳлҰ¬
    let audioUrl = selectedMeeting.audio_url || "";
    if (audioChunksRef.current && audioChunksRef.current.length > 0) {
      try {
        const audioBlob = new Blob(audioChunksRef.current, { type: "audio/webm" });
        const formData = new FormData();
        formData.append("file", audioBlob, `meeting-${selectedMeeting.id}.webm`);

        console.log("рҹҺҷпёҸ Uploading recorded audio blob to server...");
        const uploadRes = await fetch("/api/meeting-minutes/upload", {
          method: "POST",
          body: formData
        });
        const uploadData = await uploadRes.json();
        if (uploadData.success) {
          audioUrl = uploadData.audioUrl;
          console.log("рҹҺҷпёҸ Audio upload success:", audioUrl);
        } else {
          console.warn("рҹҺҷпёҸ Audio upload failed:", uploadData.error);
        }
      } catch (uploadErr) {
        console.error("рҹҺҷпёҸ Audio upload exception:", uploadErr);
      }
    }

    // лҢҖнҷ”лЎқ мқјкҙ„ м№ҳнҷҳ мІҳлҰ¬ (мһ„мӢң нҷ”мһҗлӘ… -> мӢӨм ң л§Өн•‘ мқҙлҰ„)
    const mappedTranscript = transcript.map(item => {
      const mappedName = speakerMapping[item.speaker] || item.speaker;
      return {
        ...item,
        speaker: mappedName.trim() ? mappedName.trim() : item.speaker
      };
    });

    // л§Өн•‘лҗң мӢӨм ң нҷ”мһҗлӘ… лӘ…лӢЁ м¶”м¶ң (мң лӢҲнҒ¬ мІҳлҰ¬)
    const uniqueMappedNames = Array.from(new Set(Object.values(speakerMapping)))
      .map(name => name.trim())
      .filter(name => name && !name.startsWith("нҷ”мһҗ "));
    
    const finalAttendees = uniqueMappedNames.map(name => ({
      name,
      email: `${name}@company.com`
    }));

    try {
      const res = await fetch("/api/meeting-minutes", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          action: "complete",
          meetingId: selectedMeeting.id,
          transcript: mappedTranscript,
          attendees: finalAttendees.length > 0 ? finalAttendees : undefined, // м°ём„қмһҗ м •ліҙ лҸҷмӢң м—…лҚ°мқҙнҠё
          audioUrl: audioUrl,
          meetingType: getMeetingType(selectedMeeting)
        })
      });
      const data = await res.json();
      if (data.success) {
        setSelectedMeeting(data.meeting);
        setTasks(data.tasks || []);

        if (selectedMeeting && typeof window !== "undefined" && (window as any).__ongoing_meeting_audio_chunks) {
          delete (window as any).__ongoing_meeting_audio_chunks[selectedMeeting.id];
        }
        
        let attendeesArr = [];
        try {
          attendeesArr = JSON.parse(data.meeting.attendees || "[]");
        } catch (e) {
          attendeesArr = [];
        }
        setSendRecipients(attendeesArr);
        setMailResult(null);

        setDetailTab("summary");
        setViewMode("detail");
        fetchMeetings();
      } else {
        alert(data.error || "нҡҢмқҳ л¶„м„қ мІҳлҰ¬м—җ мӢӨнҢЁн–ҲмҠөлӢҲлӢӨ.");
      }
    } catch (e) {
      console.error("нҡҢмқҳ мў…лЈҢ мҳӨлҘҳ:", e);
    } finally {
      setIsCompleting(false);
    }
  };


  // 8. н•  мқј мІҙнҒ¬ мғҒнғң ліҖкІҪ
  const handleToggleTask = async (taskId: number, currentStatus: string) => {
    const nextStatus = currentStatus === "PENDING" ? "COMPLETED" : "PENDING";
    try {
      const res = await fetch("/api/meeting-minutes/tasks", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ taskId, status: nextStatus })
      });
      const data = await res.json();
      if (data.success) {
        // н•  мқј мғҒнғң лЎңм»¬ м—…лҚ°мқҙнҠё
        setTasks(tasks.map(t => t.id === taskId ? { ...t, status: nextStatus } : t));
      }
    } catch (e) {
      console.error("н•  мқј мғҒнғң нҶ кёҖ мӢӨнҢЁ:", e);
    }
  };

  // 9. нҡҢмқҳлЎқ л°Ҹ н•  мқј л©”мқј л°ңмҶЎ
  const handleSendEmails = async () => {
    if (sendRecipients.length === 0) {
      alert("л©”мқјмқ„ м „мҶЎн•  мҲҳмӢ мқёмқҙ м§Җм •лҗҳм§Җ м•Ҡм•ҳмҠөлӢҲлӢӨ.");
      return;
    }

    setIsSendingMail(true);
    setMailResult("мқҙл©”мқј л°ңмҶЎ м„ңлІ„(SMTP)лҘј к°ҖлҸҷн•ҳм—¬ л°°нҸ¬ мӨ‘мһ…лӢҲлӢӨ...");

    try {
      const res = await fetch("/api/meeting-minutes/send", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          meetingId: selectedMeeting.id,
          recipients: sendRecipients
        })
      });
      const data = await res.json();
      if (data.success) {
        setMailResult(`рҹҺү мқҙл©”мқј л°°нҸ¬ мҷ„лЈҢ! ${data.message}`);
      } else {
        setMailResult(`вҡ пёҸ мқјл¶Җ л°ңмҶЎ м—җлҹ¬: ${data.error}`);
      }
    } catch (e: any) {
      console.error("л©”мқј л°ңмҶЎ м—җлҹ¬:", e);
      setMailResult("вқҢ SMTP л°ңмҶЎ м„ңлІ„ м—°кІ° мӨ‘ нғҖмһ„м•„мӣғ мҳӨлҘҳк°Җ л°ңмғқн–ҲмҠөлӢҲлӢӨ. мӢңмҠӨн…ң м„Өм •мқҳ SMTP кі„м •мқ„ нҷ•мқён•ҙ мЈјм„ёмҡ”.");
    } finally {
      setIsSendingMail(false);
    }
  };

  // кіјкұ° нҡҢмқҳлЎқ ліҙкё° нҒҙлҰӯ мӢң
  const handleViewPastMeeting = async (pastId: number) => {
    try {
      const res = await fetch("/api/meeting-minutes");
      const data = await res.json();
      if (data.success) {
        const past = data.meetings.find((m: any) => m.id === pastId);
        if (past) {
          setViewPastSummary(past);
        }
      }
    } catch (e) {
      console.error("кіјкұ° нҡҢмқҳ мЎ°нҡҢ м—җлҹ¬:", e);
    }
  };

  // лҰ¬мҠӨнҠё лӘЁл“ңм—җм„ң мҷ„лЈҢлҗң нҡҢмқҳ м№ҙл“ң нҒҙлҰӯ мӢң мғҒм„ёлЎң мқҙлҸҷ
  const handleSelectMeetingCard = (meeting: any) => {
    setSelectedMeeting(meeting);
    setTempAudioUrl(meeting.audio_url || "");
    fetchTasks(meeting.id);
    
    let attendeesArr = [];
    try {
      attendeesArr = JSON.parse(meeting.attendees || "[]");
    } catch (e) {
      attendeesArr = [];
    }
    setSendRecipients(attendeesArr);
    setMailResult(null);

    // лҢҖнҷ”лЎқ ліөкө¬
    try {
      const parsedTrans = JSON.parse(meeting.transcript || "[]");
      setTranscript(parsedTrans);
    } catch (e) {
      setTranscript([]);
    }

    if (meeting.status === "ONGOING") {
      setViewMode("active");
    } else {
      setViewMode("detail");
    }
  };

  return (
    <div className="space-y-6 pb-20 w-full min-w-0 text-slate-800 animate-fade-in"
      data-easybot-hint="нҡҢмқҳ кё°лЎқ AI: л§ҲмқҙнҒ¬ STT л°Ҹ к°ҖмғҒ мӢңл®¬л Ҳмқҙм…ҳмқ„ нҶөн•ҙ мӢӨмӢңк°„ лҢҖнҷ”лЎқмқ„ мһ‘м„ұн•ҳкі , кіјкұ° нҡҢмқҳ мӢңл§ЁнӢұ м¶”мІң, мў…лЈҢ нӣ„ AI мһҗлҸҷ нҡҢмқҳлЎқ кё°м•Ҳ л°Ҹ н• мқј мқҙл©”мқј л°ңмҶЎ кё°лҠҘмқ„ нҶөн•© м ңкіөн•©лӢҲлӢӨ.">
      
      {/* мғҒлӢЁ нғҖмқҙнӢҖ н—ӨлҚ” */}
      <div className="flex flex-col lg:flex-row lg:items-center justify-between gap-6 mb-8 pb-6 border-b border-slate-200 relative z-10 shrink-0">
        <div className="space-y-1">
          <h1 className="text-3xl font-bold text-slate-800 tracking-tight flex items-center">
            <Mic className="w-8 h-8 text-indigo-600 mr-3" />
            нҡҢмқҳ кё°лЎқ AI
          </h1>
        </div>
        
        {viewMode !== "list" && (
          <button 
            onClick={() => {
              stopSTT();
              setViewMode("list");
              fetchMeetings();
            }}
            className="flex items-center space-x-2 px-5 py-3 bg-white hover:bg-slate-50 text-slate-700 rounded-xl font-semibold border border-slate-200 shadow-sm active:scale-95 transition-all cursor-pointer"
          >
            <ArrowLeft className="w-4.5 h-4.5" />
            <span>нҡҢмқҳ лӘ©лЎқмңјлЎң</span>
          </button>
        )}
      </div>

      {/* 1. нҡҢмқҳлЎқ лӘ©лЎқ л·° (List Mode) */}
      {viewMode === "list" && (
        <div className="space-y-6">
          <div className="flex justify-between items-center">
            <h2 className="text-xl font-bold text-slate-800 flex items-center space-x-2">
              <FileText className="w-5 h-5 text-indigo-600" />
              <span>м§„н–үлҗң нҡҢмқҳ лҢҖмһҘ ({meetings.length}кұҙ)</span>
            </h2>
            <button 
              onClick={() => setShowCreateModal(true)}
              className="flex items-center space-x-2 px-5 py-3 bg-gradient-to-r from-indigo-500 to-indigo-600 hover:from-indigo-600 hover:to-indigo-700 text-white rounded-xl font-bold shadow-lg shadow-indigo-950/10 active:scale-95 transition-all border border-indigo-400/20"
            >
              <Plus className="w-4 h-4" />
              <span>мӢ к·ң нҡҢмқҳ к°ңмӢң</span>
            </button>
          </div>

          {meetings.length === 0 ? (
            <div className="bg-slate-50 border border-slate-200 rounded-2xl p-16 text-center">
              <Mic className="w-12 h-12 text-slate-400 mx-auto mb-4" />
              <p className="text-slate-600 font-semibold">м•„м§Ғ кё°лЎқлҗң нҡҢмқҳлЎқмқҙ м—ҶмҠөлӢҲлӢӨ.</p>
              <p className="text-slate-500 text-xs mt-1">мҡ°мёЎ мғҒлӢЁмқҳ [мӢ к·ң нҡҢмқҳ к°ңмӢң] лІ„нҠјмқ„ лҲҢлҹ¬ мІ« лІҲм§ё нҡҢмқҳлҘј мӢӨмӢңк°„ кё°лЎқн•ҙ ліҙм„ёмҡ”.</p>
            </div>
          ) : (
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {meetings.map((meeting) => {
                let attCount = 0;
                try {
                  const arr = JSON.parse(meeting.attendees || "[]");
                  attCount = arr.length;
                } catch(e) {}

                return (
                  <div 
                    key={meeting.id}
                    onClick={() => handleSelectMeetingCard(meeting)}
                    className="group bg-white hover:bg-slate-50/50 border border-slate-200 hover:border-indigo-200 rounded-2xl p-5 cursor-pointer transition-all duration-300 shadow-sm hover:shadow-md relative overflow-hidden"
                  >
                    <div className="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-indigo-500 to-purple-500"></div>
                    <div className="flex justify-between items-start mb-3">
                      <div className="flex items-center space-x-1.5">
                        <span className={`text-[10px] px-2 py-0.5 rounded-full font-bold ${meeting.status === 'ONGOING' ? 'bg-red-50 text-red-600 border border-red-200' : 'bg-green-50 text-green-600 border border-green-200'}`}>
                          {meeting.status === 'ONGOING' ? 'рҹ”ҙ м§„н–ү мӨ‘' : 'вң… мҷ„лЈҢлҗЁ'}
                        </span>
                        {getMeetingType(meeting) === "text" ? (
                          <span className="text-[10px] px-2 py-0.5 rounded-full font-bold bg-purple-50 text-purple-650 border border-purple-200">
                            рҹ’¬ н…ҚмҠӨнҠё м—…лЎңл“ң
                          </span>
                        ) : getMeetingAudioUrl(meeting) ? (
                          <span className={`text-[10px] px-2 py-0.5 rounded-full font-bold ${getMeetingAudioUrl(meeting).includes("meeting-") ? "bg-blue-50 text-blue-600 border border-blue-200" : "bg-teal-50 text-teal-650 border border-teal-200"}`}>
                            {getMeetingAudioUrl(meeting).includes("meeting-") ? "рҹҺҷпёҸ мӢӨмӢңк°„ л…№мқҢ" : "рҹ“Ғ нҢҢмқј м—…лЎңл“ң"}
                          </span>
                        ) : null}
                      </div>
                      <div className="flex items-center space-x-2">
                        <span className="text-[11px] text-slate-400 flex items-center space-x-1">
