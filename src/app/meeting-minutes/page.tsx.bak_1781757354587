  const [tasks, setTasks] = useState<any[]>([]);
  const [viewMode, setViewMode] = useState<"list" | "active" | "detail">("list");

  // нҡҢмқҳлӘ… м§Ғм ‘ мҲҳм • кҙҖл Ё мғҒнғң
  const [isEditingTitle, setIsEditingTitle] = useState(false);
  const [editingTitleVal, setEditingTitleVal] = useState("");

  // мӢӨмӢңк°„/м—…лЎңл“ң нҡҢмқҳ мҳӨл””мҳӨ мӣҗліё мһ¬мғқ URL
  const [tempAudioUrl, setTempAudioUrl] = useState<string>("");

  // нҡҢмқҳлӘ… мҲҳм • м ҖмһҘ н•ёл“Өлҹ¬
  const handleSaveTitle = async (meetingId: number, newTitleVal: string) => {
    const trimmed = newTitleVal.trim();
    if (!trimmed) {
      alert("нҡҢмқҳлӘ…мқ„ мһ…л Ҙн•ҙмЈјм„ёмҡ”.");
      return;
    }
    try {
      const res = await fetch("/api/meeting-minutes", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          action: "sync",
          meetingId,
          title: trimmed
        })
      });
      const data = await res.json();
      if (data.success) {
        if (selectedMeeting && selectedMeeting.id === meetingId) {
          setSelectedMeeting((prev: any) => ({ ...prev, title: trimmed }));
        }
        setIsEditingTitle(false);
        fetchMeetings(); // лӘ©лЎқ к°ұмӢ 
      } else {
        alert(data.error || "нҡҢмқҳлӘ… ліҖкІҪм—җ мӢӨнҢЁн–  // л§ҲмқҙнҒ¬ л…№мқҢ/м—…лЎңл“ң нҢҢмқј мҳӨл””мҳӨ URL м¶”м¶ң н—¬нҚј н•ЁмҲҳ (м—җл®¬л Ҳмқҙн„° мҠӨнӮӨл§Ҳ мәҗмӢң мң мӢӨ мҡ°нҡҢ)
  const getMeetingAudioUrl = (meet: any) => {
    if (!meet) return "";
    if (meet.audio_url) return meet.audio_url;
    if (meet.summary) {
      const match = meet.summary.match(/\[audio_url\]:\s*(.+)/);
      if (match) return match[1].trim();
    }
    return "";
  };

  // нҡҢмқҳ нғҖмһ…(мӢӨмӢңк°„/мҳӨл””мҳӨм—…лЎңл“ң/н…ҚмҠӨнҠё) л°ҳнҷҳ н•ЁмҲҳ
  const getMeetingType = (meet: any): "audio" | "text" => {
    if (!meet) return "audio";
    if (meet.meeting_type) return meet.meeting_type;
    if (meet.summary) {
      const match = meet.summary.match(/\[meeting_type\]:\s*(.+)/);
      if (match) return match[1].trim() as any;
    }
    // мҳӨл””мҳӨ URLмқҙ мһҲмңјл©ҙ audio, м—Ҷмңјл©ҙ text
    if (getMeetingAudioUrl(meet)) return "audio";
    return "text";
  };

  // л§ҲнҒ¬лӢӨмҡҙ мҡ”м•Ҫм—җм„ң 1мӨ„ мҡ”м•Ҫ м¶”м¶ңн•ҳлҠ” н—¬нҚј н•ЁмҲҳ
  const getOneLineSummary = (summaryText: string) => {
    if (!summaryText) return "мҡ”м•Ҫ м •ліҙк°Җ м•„м§Ғ мһ‘м„ұлҗҳм§Җ м•Ҡм•ҳмҠөлӢҲлӢӨ.";
    
    // [audio_url] л°Ҹ [meeting_type] л©”нғҖлҚ°мқҙн„° л§ҒнҒ¬ ліёл¬ём—җм„ң лҸ„л ӨлӮҙкё°
    const cleanSummaryText = summaryText
      .replace(/\[audio_url\]:\s*.*/g, "")
      .replace(/\[meeting_type\]:\s*.*/g, "")
      .trim();
    if (!cleanSummaryText) return "мҡ”м•Ҫ м •ліҙк°Җ м•„м§Ғ мһ‘м„ұлҗҳм§Җ м•Ҡм•ҳмҠөлӢҲлӢӨ.";

    // л§ҲнҒ¬лӢӨмҡҙ л¬ёлІ• м ңкұ° (#, *, ` л“ұ)
    const cleanText = cleanSummaryText
      .replace(/[#*`_\-]/g, "") // л§ҲнҒ¬лӢӨмҡҙ кё°нҳё м ңкұ°
      .replace(/\[.*?\]/g, "")  // лҢҖкҙ„нҳёмҷҖ л§ҒнҒ¬ м ңкұ°н„° л§ҒнҒ¬ ліёл¬ём—җм„ң лҸ„л ӨлӮҙкё°
    const cleanSummaryText = summaryText.replace(/\[audio_url\]:\s*.*/g, "").trim();
    if (!cleanSummaryText) return "мҡ”м•Ҫ м •ліҙк°Җ м•„м§Ғ мһ‘м„ұлҗҳм§Җ м•Ҡм•ҳмҠөлӢҲлӢӨ.";

    // л§ҲнҒ¬лӢӨмҡҙ л¬ёлІ• м ңкұ° (#, *, ` л“ұ)
    const cleanText = cleanSummaryText
      .replace(/[#*`_\-]/g, "") // л§ҲнҒ¬лӢӨмҡҙ кё°нҳё м ңкұ°
      .replace(/\[.*?\]/g, "")  // лҢҖкҙ„нҳёмҷҖ л§ҒнҒ¬ м ңкұ°
      .replace(/\s+/g, " ")     // лӢӨмӨ‘ кіөл°ұ лӢЁмқј кіөл°ұмңјлЎң м№ҳнҷҳ
      .trim();

    // 0. н•ңмӨ„ мҡ”м•Ҫ л¶Җл¶„мқ„ лӘ…мӢңм ҒмңјлЎң м°ҫкё°
    const oneLineMatch = cleanText.match(/н•ңмӨ„\s*мҡ”м•Ҫ\s*:\s*(.*?)(?=\s*[0-9]\.|\s*нҡҢмқҳ\s*к°ңмҡ”|$)/i);
    if (oneLineMatch && oneLineMatch[1]) {
      const matchedText = oneLineMatch[1].trim();
      return matchedText.length > 200 ? matchedText.slice(0, 200) + "..." : matchedText;
    }

    // [н•ңмӨ„ мҡ”м•Ҫ] нҢЁн„ҙ л§Өм№ӯ
    const bracketMatch = cleanText.match(/\[н•ңмӨ„\s*мҡ”м•Ҫ\]\s*(.*?)(?=\s*[0-9]\.|\s*нҡҢмқҳ\s*к°ңмҡ”|$)/i);
    if (bracketMatch && bracketMatch[1]) {
      const matchedText = bracketMatch[1].trim();
      return matchedText.length > 200 ? matchedText.slice(0, 200) + "..." : matchedText;
    }

    // л§Ңм•Ҫ мҡ”м•Ҫм„ң л§Ё м•һл¶Җл¶„м—җ "нҡҢмқҳ к°ңмҡ”" нҳ№мқҖ "мқјмӢң" л©”нғҖлҚ°мқҙн„°к°Җ лӮҳмҳЁлӢӨл©ҙ, мқҙлҘј кұҙл„Ҳлӣ°кі 
    // "мЈјмҡ” мқҳм ң л°Ҹ кІ°м • мӮ¬н•ӯ"мқҙлӮҳ к·ё мқҙнӣ„мқҳ мӢӨм§Ҳм Ғмқё мҡ”м•Ҫ н…ҚмҠӨнҠёлҘј м¶”м¶ң
    const agendaIndex = cleanText.indexOf("мЈјмҡ” мқҳм ң л°Ҹ кІ°м • мӮ¬н•ӯ");
    if (agendaIndex !== -1) {
      const remainingText = cleanText.slice(agendaIndex + "мЈјмҡ” мқҳм ң л°Ҹ кІ°м • мӮ¬н•ӯ".length).trim();
      // нҳ№мӢң л’Өм—җ мҲ«мһҗк°Җ мҳӨкұ°лӮҳ мҪңлЎ мқҙ мҳӨл©ҙ м ңкұ°
      const cleanedRemaining = remainingText.replace(/^[:\s\d.]+/g, "").trim();
      if (cleanedRemaining.length > 10) {
        return cleanedRemaining.length > 200 ? cleanedRemaining.slice(0, 200) + "..." : cleanedRemaining;
      }
    }

    const discussionIndex = cleanText.indexOf("мЈјмҡ” л…јмқҳ лӮҙмҡ©");
    if (discussionIndex !== -1) {
      const remainingText = cleanText.slice(discussionIndex + "мЈјмҡ” л…јмқҳ лӮҙмҡ©".length).trim();
      const cleanedRemaining = remainingText.replace(/^[:\s\d.]+/g, "").trim();
      if (cleanedRemaining.length > 10) {
        return cleanedRemaining.length > 200 ? cleanedRemaining.slice(0, 200) + "..." : cleanedRemaining;
      }
    }

    // нҸҙл°ұ: "нҡҢмқҳ к°ңмҡ”" н…ҚмҠӨнҠё л¶Җл¶„мқ„ мӮӯм ңн•ҳм—¬ мІ« мӢӨм§Ҳм Ғ лӮҙмҡ© м¶”м¶ң мӢңлҸ„
    let fallbackText = cleanText;
    if (fallbackText.includes("нҡҢмқҳ к°ңмҡ”")) {
      fallbackText = fallbackText.split("нҡҢмқҳ к°ңмҡ”")[1] || fallbackText;
      // мқјмӢң, м°ём„қмһҗ лҚ°мқҙн„°к°Җ мқҙм–ҙм„ң лӮҳмҳӨл©ҙ мқҙкІғлҸ„ мҠ¬лқјмқҙмӢұ
      const attendeeIndex = fallbackText.indexOf("м°ём„қмһҗ");
      if (attendeeIndex !== -1) {
        // м°ём„қмһҗ лӘ…лӢЁ мқҙнӣ„мқҳ н…ҚмҠӨнҠё
        const temp = fallbackText.slice(attendeeIndex).trim();
        const nextDotIndex = temp.indexOf(".");
        if (nextDotIndex !== -1 && temp.slice(nextDotIndex + 1).trim().length > 10) {
          fallbackText = temp.slice(nextDotIndex + 1).trim();
        }
      }
    }

    fallbackText = fallbackText.replace(/^[:\s\d.]+/g, "").trim();
    return fallbackText.length > 200 ? fallbackText.slice(0, 200) + "..." : fallbackText;
  };
  
  // мғҲ нҡҢмқҳ мһ‘м„ұ нҸј
  const [newTitle, setNewTitle] = useState("");
  const [attendeeName, setAttendeeName] = useState("");
  const [attendeeEmail, setAttendeeEmail] = useState("");
  const [tempAttendees, setTempAttendees] = useState<{ name: string; email: string }[]>([]);
  const [showCreateModal, setShowCreateModal] = useState(false);

  // мӢӨмӢңк°„ нҡҢмқҳ мӨ‘ мғҒнғң
  const [isRecording, setIsRecording] = useState(false);
  const [transcript, setTranscript] = useState<{ id: string; speaker: string; text: string; time: string; isDiarizing?: boolean }[]>([]);
  const [currentSpeech, setCurrentSpeech] = useState("");
  const [speechSpeaker, setSpeechSpeaker] = useState("нҷ”мһҗ 1");
  const speechSpeakerRef = useRef("нҷ”мһҗ 1");

  useEffect(() => {
    speechSpeakerRef.current = speechSpeaker;
  }, [speechSpeaker]);

  // лҸҷм Ғ к°Җм№ӯ нҷ”мһҗ лҰ¬мҠӨнҠё мғҒнғң
  const [activeSpeakers, setActiveSpeakers] = useState<string[]>(["нҷ”мһҗ 1", "нҷ”мһҗ 2", "нҷ”мһҗ 3", "нҷ”мһҗ 4"]);
  
  // нҷ”мһҗ л§Өн•‘ л°Ҹ лӘЁлӢ¬ мғҒнғң
  const [showMappingModal, setShowMappingModal] = useState(false);
  const [speakerMapping, setSpeakerMapping] = useState<Record<string, string>>({});

  // мғҒм„ё ліҙкё° нҷ”л©ҙ нғӯ мғҒнғң
  const [detailTab, setDetailTab] = useState<"summary" | "transcript">("summary");

  // лҢҖнҷ”лЎқ(transcript)м—җ кё°мһ¬лҗң мһ„мӢң нҷ”мһҗк°Җ мғқкІЁлӮҳл©ҙ activeSpeakersм—җ мһҗлҸҷ лҲ„м Ғ лҸҷкё°нҷ”
  useEffect(() => {
    if (transcript && transcript.length > 0) {
      const uniqueSpeakers = Array.from(new Set(transcript.map(t => t.speaker)));
      setActiveSpeakers(prev => {
        const next = [...prev];
        let changed = false;
        uniqueSpeakers.forEach(sp => {
          if (sp && sp.startsWith("нҷ”мһҗ ") && !next.includes(sp)) {
            next.push(sp);
            changed = true;
          }
        });
        if (changed) {
          return next.sort((a, b) => {
            const numA = parseInt(a.replace("нҷ”мһҗ ", "")) || 0;
            const numB = parseInt(b.replace("нҷ”мһҗ ", "")) || 0;
            return numA - numB;
          });
        }
        return prev;
      });
    }
  }, [transcript]);

  // selectedMeeting ліҖкІҪ мӢң нҷ”мһҗлҘј кё°ліё "нҷ”мһҗ 1"лЎң м„ёнҢ…
  useEffect(() => {
    setSpeechSpeaker("нҷ”мһҗ 1");
  }, [selectedMeeting]);

  // м§„н–ү мӨ‘мқё нҡҢмқҳ ліөмӣҗ мӢң м „м—ӯм—җ ліҙмЎҙлҗң мҳӨл””мҳӨ мІӯнҒ¬ ліөкө¬
  useEffect(() => {
    if (selectedMeeting && typeof window !== "undefined") {
      const meetId = selectedMeeting.id;
      const backup = (window as any).__ongoing_meeting_audio_chunks?.[meetId];
      if (backup && backup.length > 0) {
        audioChunksRef.current = [...backup];
        console.log(`рҹҺҷпёҸ Backup audio chunks restored for meeting ${meetId}. Size:`, backup.length);
      }
    }
  }, [selectedMeeting]);

  const getActiveAttendees = () => {
    if (!selectedMeeting) return ["лӮҳ (нҡҢмқҳ м°ём—¬мһҗ)", "нҷҚкёёлҸҷ лҢҖн‘ң", "к№ҖмІ мҲҳ кіјмһҘ", "мқҙмҳҒнқ¬ лҢҖлҰ¬"];
    try {
      const parsed = JSON.parse(selectedMeeting.attendees || "[]");
      if (Array.isArray(parsed) && parsed.length > 0) {
        return parsed.map((a: any) => a.name);
      }
    } catch (e) {
      console.error("м°ём„қмһҗ лӘ©лЎқ мЎ°нҡҢ мҳӨлҘҳ:", e);
    }
    return ["лӮҳ (нҡҢмқҳ м°ём—¬мһҗ)", "нҷҚкёёлҸҷ лҢҖн‘ң", "к№ҖмІ мҲҳ кіјмһҘ", "мқҙмҳҒнқ¬ лҢҖлҰ¬"];
  };
  const [recommendedMeetings, setRecommendedMeetings] = useState<any[]>([]);
  const [interimAdvice, setInterimAdvice] = useState<string>("");
  const [showInterimModal, setShowInterimModal] = useState(false);
  const [isAnalyzingInterim, setIsAnalyzingInterim] = useState(false);
  const [isCompleting, setIsCompleting] = useState(false);

  // мҳӨл””мҳӨ нҢҢмқј м—…лЎңл“ң л°Ҹ л¶„м„қ мғҒнғң
  const [isAudioAnalyzing, setIsAudioAnalyzing] = useState(false);
  const [audioAnalysisStep, setAudioAnalysisStep] = useState("");

  // кіјкұ° нҡҢмқҳ мҡ”м•Ҫ л·°м–ҙ лӘЁлӢ¬
  const [viewPastSummary, setViewPastSummary] = useState<any | null>(null);

  // мқҙл©”мқј л°ңмҶЎ кҙҖл Ё
  const [sendRecipients, setSendRecipients] = useState<{ name: string; email: string }[]>([]);
  const [isSendingMail, setIsSendingMail] = useState(false);
  const [mailResult, setMailResult] = useState<string | null>(null);

  // Refs
  const shouldSTTActiveRef = useRef(false);
  const recognitionRef = useRef<any>(null);

  const transcriptEndRef = useRef<HTMLDivElement>(null);
  const lastRecommendLengthRef = useRef<number>(0);

  // рҹҺҷпёҸ MediaRecorder мғҒнғң л°Ҹ Refs м¶”к°Җ
  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const audioChunksRef = useRef<Blob[]>([]);
  const [audioStream, setAudioStream] = useState<MediaStream | null>(null);

  // 1. мҙҲкё° лЎңл”©: нҡҢмқҳлЎқ лӘ©лЎқ нҡҚл“қ л°Ҹ м§„н–ү мӨ‘мқё нҡҢмқҳ ліөкө¬
  useEffect(() => {
    const initFetch = async () => {
      try {
        const res = await fetch("/api/meeting-minutes");
        const data = await res.json();
        if (data.success) {
          setMeetings(data.meetings);
          
          // м§„н–ү мӨ‘мқё нҡҢмқҳ(ONGOING)к°Җ мЎҙмһ¬н•ҳл©ҙ мҰүмӢң ліөкө¬ л°Ҹ нҡҢмқҳ нҷ”л©ҙ м§„мһ…
          const ongoingMeeting = data.meetings.find((m: any) => m.status === "ONGOING");
          if (ongoingMeeting) {
            setSelectedMeeting(ongoingMeeting);
            try {
              const parsedTrans = JSON.parse(ongoingMeeting.transcript || "[]");
              setTranscript(parsedTrans);
            } catch (e) {
              console.error("м§„н–ү мӨ‘мқё нҡҢмқҳ лҢҖнҷ”лЎқ ліөкө¬ мӢӨнҢЁ:", e);
              setTranscript([]);
            }
            setViewMode("active");
          }
        }
      } catch (e) {
        console.error("мҙҲкё° лӘ©лЎқ мЎ°нҡҢ мӢӨнҢЁ:", e);
      }
    };

    initFetch();
  }, []);

  // 1-1. лҢҖнҷ”лЎқ мӢӨмӢңк°„ л°ұк·ёлқјмҡҙл“ң лҸҷкё°нҷ” (лӢӨлҘё нҺҳмқҙм§Җ мқҙлҸҷ мӢң мң мӢӨ л°©м§Җ)
  useEffect(() => {
    if (viewMode !== "active" || !selectedMeeting) return;

    const syncTranscript = async () => {
      try {
        await fetch("/api/meeting-minutes", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            action: "sync",
            meetingId: selectedMeeting.id,
            transcript: transcript
          })
        });
      } catch (e) {
        console.error("нҡҢмқҳлЎқ мӢӨмӢңк°„ лҸҷкё°нҷ” м—җлҹ¬:", e);
      }
    };

    const timer = setTimeout(syncTranscript, 1000);
    return () => clearTimeout(timer);
  }, [transcript, viewMode, selectedMeeting]);

  // лҢҖнҷ”лЎқ м¶”к°Җ мӢң н•ҳлӢЁ мҠӨнҒ¬лЎӨ мһҗлҸҷ мқҙлҸҷ
  useEffect(() => {
    transcriptEndRef.current?.scrollIntoView({ behavior: "smooth" });
    
    // нҡҢмқҳ м§„н–ү мӨ‘, лҢҖнҷ”лҹүмқҙ 3л¬ёмһҘ м¶”к°Җлҗ  л•Ңл§ҲлӢӨ кіјкұ° нҡҢмқҳ мӢңл§ЁнӢұ м¶”мІң нҠёлҰ¬кұ°
    if (viewMode === "active" && transcript.length > 0 && transcript.length % 3 === 0 && transcript.length !== lastRecommendLengthRef.current) {
      lastRecommendLengthRef.current = transcript.length;
      triggerSemanticRecommendation();
    }
  }, [transcript, viewMode]);

  const fetchMeetings = async () => {
    try {
      const res = await fetch("/api/meeting-minutes");
      const data = await res.json();
      if (data.success) {
        setMeetings(data.meetings);
      }
    } catch (e) {
      console.error("нҡҢмқҳ лӘ©лЎқ мЎ°нҡҢ мӢӨнҢЁ:", e);
    }
  };

  const handleDeleteMeeting = async (e: React.MouseEvent, meetingId: number) => {
    e.stopPropagation(); // м№ҙл“ң мғҒм„ёліҙкё° нҒҙлҰӯ мқҙлІӨнҠё м°ЁлӢЁ

    if (!confirm("м •л§җлЎң мқҙ нҡҢмқҳлЎқмқ„ мӮӯм ңн•ҳмӢңкІ мҠөлӢҲк№Ң?\nмӮӯм ңлҗң лҚ°мқҙн„°лҠ” ліөкө¬н•  мҲҳ м—ҶмҠөлӢҲлӢӨ.")) {
      return;
    }

    try {
      const res = await fetch(`/api/meeting-minutes?meetingId=${meetingId}`, {
        method: "DELETE"
      });
      const data = await res.json();
      if (data.success) {
        alert("нҡҢмқҳлЎқмқҙ м„ұкіөм ҒмңјлЎң мӮӯм ңлҗҳм—ҲмҠөлӢҲлӢӨ.");
        fetchMeetings(); // лӘ©лЎқ к°ұмӢ 
      } else {
        alert(data.error || "нҡҢмқҳлЎқ мӮӯм ңм—җ мӢӨнҢЁн–ҲмҠөлӢҲлӢӨ.");
      }
    } catch (err) {
      console.error("нҡҢмқҳлЎқ мӮӯм ң мҳӨлҘҳ:", err);
      alert("м„ңлІ„ нҶөмӢ  мӨ‘ мҳӨлҘҳк°Җ л°ңмғқн–ҲмҠөлӢҲлӢӨ.");
